#!/bin/bash
# S2I assemble script - runs when Showroom builds the content container
# This substitutes environment variables in the Antora playbook

echo "=== Custom S2I Assemble - Injecting Environment Variables ==="

# Run the default assemble script first
/usr/libexec/s2i/assemble

# Substitute environment variables in the playbook
if [ -f "/opt/app-root/src/default-site.yml" ]; then
  echo "Substituting environment variables in default-site.yml..."
  envsubst < /opt/app-root/src/default-site.yml > /opt/app-root/src/default-site.yml.tmp
  mv /opt/app-root/src/default-site.yml.tmp /opt/app-root/src/default-site.yml
  echo "✓ Environment variables substituted"
else
  echo "⚠ default-site.yml not found"
fi

echo "=== End Custom S2I Assemble ==="
