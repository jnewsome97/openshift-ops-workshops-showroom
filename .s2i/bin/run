#!/bin/bash
# S2I run script - runs when the Showroom container starts
# Environment variables from ConfigMap are available here

echo "=== Custom Showroom Run Script ==="
echo "Substituting environment variables before building site..."

# Set defaults for missing variables
export API_URL=${API_URL:-}
export MASTER_URL=${MASTER_URL:-}
export KUBEADMIN_PASSWORD=${KUBEADMIN_PASSWORD:-}
export SSH_USERNAME=${SSH_USERNAME:-}
export SSH_PASSWORD=${SSH_PASSWORD:-}
export BASTION_FQDN=${BASTION_FQDN:-}
export GUID=${GUID:-}
export ROUTE_SUBDOMAIN=${ROUTE_SUBDOMAIN:-}
export HOME_PATH=${HOME_PATH:-/home/lab-user}
export ENVIRONMENT=${ENVIRONMENT:-Amazon Web Services}

# Substitute environment variables in the Antora playbook
if [ -f "/opt/app-root/src/default-site.yml" ]; then
  echo "Processing default-site.yml..."
  envsubst < /opt/app-root/src/default-site.yml > /tmp/default-site.yml
  mv /tmp/default-site.yml /opt/app-root/src/default-site.yml
  echo "✓ Variables substituted in playbook"
fi

# Now run the default Showroom run script
exec /usr/libexec/s2i/run
